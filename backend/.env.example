# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=finance_app
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=24

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# OAuth - Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:8080/auth/microsoft/callback

# OAuth - Session
OAUTH_SESSION_SECRET=change-me-in-production

# Application Configuration
APP_URL=http://localhost:8080
ENV=development

# Admin impersonation (support troubleshooting)
# Admins (users.is_admin = true, granted via migration) can impersonate
# non-admin users for troubleshooting; every action is audited under the
# admin's identity.
# How long an impersonation token stays valid, in minutes (default 30).
IMPERSONATION_TOKEN_TTL_MINUTES=30
