FROM golang:1.25-alpine

WORKDIR /app

# Install build dependencies
RUN apk add --no-cache git

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Note: We don't build here - we'll use go run in docker-compose
# This keeps Go available for hot-reloading during development

EXPOSE 8090

# Default command (can be overridden in docker-compose)
CMD ["go", "run", "cmd/server/main.go"]
