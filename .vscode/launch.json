  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server/main.go",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "5442"
      }
    },
    {
      "name": "Seed Script",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/scripts/seed/main.go",
      "envFile": "${workspaceFolder}/backend/.env",
      "args": ["matdeitos@gmail.com"],
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "5442"
      }
    },
    {
      "name": "Script",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/scripts/consolidate_recurrences/main.go",
      "envFile": "${workspaceFolder}/backend/.env.prod",
      "args": []
    }
  ]
}
