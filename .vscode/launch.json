  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server/main.go",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "5442"
      }
    },
    {
      "name": "Seed Script",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/scripts/seed/main.go",
      "envFile": "${workspaceFolder}/backend/.env",
      "args": ["matdeitos@gmail.com"],
      "env": {
        "DB_HOST": "localhost",
        "DB_PORT": "5442"
      }
    },
    {
      "name": "Debug TransactionUpdate Test",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/backend/internal/service",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "-test.run",
        "TestTransactionUpdateWithDB",
        "-testify.m",
        "TestScenario2_OwnExpenseToOwnIncomeWithLinkedTransactions",
        "-test.v"
      ]
    }
  ]
}
