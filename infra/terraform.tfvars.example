# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

# ── GCP Project ───────────────────────────────────────────────────────────────
gcp_project_id = "my-gcp-project-id"   # GCP project ID (find in GCP Console → Home)
gcp_region     = "us-central1"          # Region for Cloud Run and Artifact Registry

# ── Artifact Registry ─────────────────────────────────────────────────────────
gar_repository = "backend"              # Docker repo name in Artifact Registry
                                        # → used as GAR_REPOSITORY GitHub variable

# ── Cloud Run ─────────────────────────────────────────────────────────────────
cloud_run_service_name = "backend"      # Cloud Run service name
                                        # → used as CLOUD_RUN_SERVICE_NAME GitHub variable

# ── Database (non-sensitive) ──────────────────────────────────────────────────
db_host    = "10.0.0.2"                # Cloud SQL private IP or Cloud SQL Proxy address
db_port    = "5432"
db_user    = "finance_user"
db_name    = "finance_app"
db_sslmode = "require"

# ── OAuth – Google (optional, non-sensitive) ──────────────────────────────────
google_client_id    = ""               # Leave empty to disable Google OAuth
google_callback_url = "https://api.example.com/auth/google/callback"

# ── OAuth – Microsoft (optional, non-sensitive) ───────────────────────────────
microsoft_client_id    = ""            # Leave empty to disable Microsoft OAuth
microsoft_callback_url = "https://api.example.com/auth/microsoft/callback"

# ── Application ───────────────────────────────────────────────────────────────
app_url      = "https://api.finance-app.mateusdeitos.dev"
frontend_url = "https://finance-app.mateusdeitos.dev"

# ── Web Push / VAPID (public key + subject são NÃO-sensíveis) ─────────────────
# Gere o par com:  npx web-push generate-vapid-keys
# A pública entra aqui; a privada vai pro Secret Manager (ver abaixo).
# ATENÇÃO: gere o par UMA vez e mantenha estável — trocar a pública invalida
# todas as inscrições push já existentes dos usuários.
vapid_public_key = "B..."                                  # public key (base64url, ~87 chars)
vapid_subject    = "mailto:matdeitos@gmail.com"            # contato (mailto: ou https://) — RFC 8292

# ── Secrets (gerenciados pelo Secret Manager, NÃO entram aqui) ────────────────
#
# Após rodar `terraform apply`, adicione os valores dos secrets com:
#
#   echo -n "VALUE" | gcloud secrets versions add DB_PASSWORD          --data-file=-
#   echo -n "VALUE" | gcloud secrets versions add JWT_SECRET           --data-file=-
#   echo -n "VALUE" | gcloud secrets versions add OAUTH_SESSION_SECRET --data-file=-
#   echo -n "VALUE" | gcloud secrets versions add VAPID_PRIVATE_KEY    --data-file=-
#
# OAuth (adicionar string vazia se o provider não for usado):
#   echo -n "VALUE" | gcloud secrets versions add GOOGLE_CLIENT_SECRET    --data-file=-
#   echo -n ""      | gcloud secrets versions add MICROSOFT_CLIENT_SECRET --data-file=-
